def exception(T):
    for _ in range(T):
        data= input().split()
        try:
            print(int(data[0])//int(data[1]))
        except ZeroDivisionError as e:
            print(f"Error Code: {e}")
        except ValueError as v:
            print(f"Error Code: {v}")



if __name__ == '__main__':
    T = int(input())
    exception(T)
